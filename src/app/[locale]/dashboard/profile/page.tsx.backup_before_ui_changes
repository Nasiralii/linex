"use client";

import { useLocale } from "next-intl";
import { useState, useEffect, useRef } from "react";
import {
  User, Building2, Save, Loader2, AlertCircle, CheckCircle, Phone, MapPin, Award,
  Upload, FileText, X, Camera, Briefcase, Shield, Clock, Image as ImageIcon,
} from "lucide-react";

// G6-G10: Full profile page rebuild with document uploads, avatar, portfolio

async function loadProfile() {
  const res = await fetch("/api/auth/me");
  if (!res.ok) return null;
  return res.json();
}

async function updateProfile(data: any) {
  const res = await fetch("/api/profile", {
    method: "PUT",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(data),
  });
  return res.json();
}

export default function ProfilePage() {
  const locale = useLocale();
  const isRtl = locale === "ar";

  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState("");
  const [success, setSuccess] = useState("");
  const [profile, setProfile] = useState<any>(null);
  const [activeTab, setActiveTab] = useState("info");
  const [form, setForm] = useState<any>({});

  // Document upload refs
  const avatarRef = useRef<HTMLInputElement>(null);
  const [avatarPreview, setAvatarPreview] = useState<string | null>(null);
  const [documents, setDocuments] = useState<Record<string, File[]>>({});
  const [portfolioImages, setPortfolioImages] = useState<File[]>([]);
  const portfolioRef = useRef<HTMLInputElement>(null);

  // Calculate profile score
  const getProfileScore = () => {
    if (!profile) return { score: 0, badges: [] as string[], tips: [] as string[] };
    const p = profile.profile || {};
    let score = 0;
    const badges: string[] = [];
    const tips: string[] = [];
    if (p.fullName || p.companyName) score += 5; else tips.push(isRtl ? "أضف اسمك" : "Add your name");
    if (p.phone) score += 5; else tips.push(isRtl ? "أضف رقم الجوال" : "Add phone number");
    if (p.city) score += 5; else tips.push(isRtl ? "اختر المدينة" : "Select city");
    if (p.description || p.bio) score += 10; else tips.push(isRtl ? "أضف نبذة عنك" : "Add bio");
    const years = p.yearsInBusiness || p.yearsExperience || 0;
    score += Math.min(10, years * 2);
    if (years >= 5) badges.push("EXPERIENCED");
    if (years === 0) tips.push(isRtl ? "أضف سنوات الخبرة" : "Add experience");
    if (p.ratingAverage >= 4.5) badges.push("HIGHLY_RATED");
    score += Math.round((p.ratingAverage || 0) * 4);
    if (p.verificationStatus === "VERIFIED") { score += 10; badges.push("VERIFIED"); }
    else tips.push(isRtl ? "أكمل التحقق" : "Complete verification");
    if (p.website) score += 5; else tips.push(isRtl ? "أضف موقعك" : "Add website");
    if (p.education) score += 5;
    if (p.certifications) score += 5;
    if (p.teamSize > 0 || p.specialization) score += 5;
    return { score: Math.min(100, score), badges, tips: tips.slice(0, 4) };
  };

