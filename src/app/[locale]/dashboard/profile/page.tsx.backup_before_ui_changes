                </div>
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "1rem" }}>
                <div>
                  <label><Phone style={{ width: "14px", height: "14px", display: "inline" }} /> {isRtl ? "رقم الجوال" : "Phone"}</label>
