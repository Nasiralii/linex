                  </div>
                  <input type="text" value={form.fullName} onChange={(e) => setForm((p: any) => ({ ...p, fullName: e.target.value }))} />
                </div>
                <div>
                  <label>{isRtl ? "اللقب" : "Nickname"}</label>
                  <div style={{ fontSize: "0.75rem", color: "var(--text-muted)", marginBottom: "0.25rem" }}>
                    {isRtl ? "مرئي للجميع" : "Visible to everyone"}
                  </div>
