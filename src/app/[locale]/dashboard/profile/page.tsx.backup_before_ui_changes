  const addDocument = (category: string, files: FileList | null) => {
    if (!files) return;
    setDocuments(prev => ({
      ...prev,
      [category]: [...(prev[category] || []), ...Array.from(files)].slice(0, 5),
    }));
  };

  const removeDocument = (category: string, index: number) => {
    setDocuments(prev => ({
      ...prev,
      [category]: (prev[category] || []).filter((_, i) => i !== index),
