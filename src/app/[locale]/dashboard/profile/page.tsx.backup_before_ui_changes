        setProfile(data);
        setForm({
          fullName: data.profile?.fullName || data.profile?.companyName || "",
          fullNameAr: data.profile?.fullNameAr || data.profile?.companyNameAr || "",
          phone: data.profile?.phone || "",
          city: data.profile?.city || "",
          region: data.profile?.region || "",
          bio: data.profile?.description || data.profile?.bio || "",
          bioAr: data.profile?.descriptionAr || data.profile?.bioAr || "",
          companyName: data.profile?.companyName || "",
          companyNameAr: data.profile?.companyNameAr || "",
          yearsInBusiness: data.profile?.yearsInBusiness || data.profile?.yearsExperience || "",
          teamSize: data.profile?.teamSize || "",
          website: data.profile?.website || "",
          specialization: data.profile?.specialization || "DESIGNER",
          discipline: data.profile?.discipline || "",
          education: data.profile?.education || "",
          certifications: data.profile?.certifications || "",
          companyType: data.profile?.companyType || "individual",
        });
        if (data.profile?.avatarUrl) setAvatarPreview(data.profile.avatarUrl);
      }
      setLoading(false);
    });
