# =============================================================================
# LineX — environment variables
# =============================================================================
# Copy to `.env` or `.env.local` (local only; never commit real secrets).
# Next.js loads: .env → .env.local (overrides) → .env.development / .env.production
#
# Use ONE of the blocks below: **Local (Supabase)** for your machine, **AWS** for EC2/prod.
# S3 can stay on AWS in both cases (dev often uses the same bucket with a dev prefix or a
# separate dev bucket — your choice).
# =============================================================================

# --- Shared (all environments) ---
AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"

# --- AWS S3 (file uploads) — use the same or different buckets per environment ---
AWS_REGION="eu-central-1"
AWS_S3_BUCKET="your-bucket-name"
# NEXT_PUBLIC_S3_PUBLIC_BASE_URL="https://..."   # optional CloudFront
# AWS_ACCESS_KEY_ID=""   # only if not using EC2 instance role
# AWS_SECRET_ACCESS_KEY=""

# =============================================================================
# A) LOCAL — Supabase Postgres + optional Supabase dashboard keys
# =============================================================================
# NEXT_PUBLIC_APP_URL must match how you open the app or cookies break on HTTP.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# From Supabase → Project Settings → Database (paste password; encode special chars e.g. @ → %40)
# Runtime: pooler (transaction) or session — often port 6543 with ?pgbouncer=true
DATABASE_URL="postgresql://postgres.YOUR_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations / Prisma CLI: session pooler :5432 on pooler host, OR direct: db.YOUR_REF.supabase.co:5432
DATABASE_URL_DIRECT="postgresql://postgres.YOUR_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Optional (only if you add Supabase JS client features later)
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="..."

# =============================================================================
# B) PRODUCTION / AWS EC2 — RDS + same S3 pattern as above
# =============================================================================
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
# DATABASE_URL="postgresql://USER:PASSWORD@your-db.xxxx.region.rds.amazonaws.com:5432/postgres?sslmode=require"
# DATABASE_URL_DIRECT="postgresql://USER:PASSWORD@your-db.xxxx.region.rds.amazonaws.com:5432/postgres?sslmode=require"
