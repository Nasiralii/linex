# Copy to `.env` locally and `~/linex/.env` on EC2. Never commit real secrets.

# --- App ---
# Session cookie `Secure` matches this: use http://... until HTTPS is enabled (plain HTTP cannot use Secure cookies).
NEXT_PUBLIC_APP_URL="https://your-domain-or-ec2-ip"

# --- Auth ---
AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"

# --- AWS S3 (uploads) — attach infra/iam-ec2-s3-uploads-policy.json to EC2 role OR set keys below ---
AWS_REGION="eu-north-1"
AWS_S3_BUCKET="your-linex-uploads-bucket"
# Optional: CloudFront URL (no trailing slash); Next image domains pick this up at build time
# NEXT_PUBLIC_S3_PUBLIC_BASE_URL="https://dxxxxxxxx.cloudfront.net"

# Optional if EC2 has no instance profile:
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# --- Postgres (AWS RDS) ---
# Security group: allow EC2 → RDS port 5432
# Example (adjust user/password/host):
# postgresql://linex:PASSWORD@linex-db.xxxxx.ap-southeast-1.rds.amazonaws.com:5432/postgres?sslmode=require
DATABASE_URL="REPLACE_WITH_RDS_URL"
DATABASE_URL_DIRECT="REPLACE_WITH_RDS_URL"
